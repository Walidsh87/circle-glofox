# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL — used for absolute links (e.g. magic link redirects)
NEXT_PUBLIC_APP_URL=

# Sentry — optional, add before going to production
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Resend — automated billing reminders
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Vercel Cron auth secret (32+ random chars)
CRON_SECRET=

# Portal token signing key — HMAC for /portal/[token] (32+ random chars)
PORTAL_SIGN_SECRET=

# Rate limiting (Upstash) — optional; when BOTH are set, per-IP limiting activates
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
