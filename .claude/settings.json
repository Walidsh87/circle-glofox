{
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "node scripts/loop-deny.mjs" } ] }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run type-check)",
      "Bash(npm run lint)",
      "Bash(npm test)",
      "Bash(npm run test)",
      "Bash(npm run test:coverage)"
    ],
    "deny": [
      "mcp__supabase__apply_migration"
    ]
  }
}
