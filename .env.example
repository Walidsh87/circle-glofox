# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL — used for absolute links (e.g. magic link redirects)
NEXT_PUBLIC_APP_URL=

# Sentry — optional, add before going to production
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Resend — automated billing reminders
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# Resend webhook signing secret (from the Resend dashboard webhook). Enables open/click analytics.
RESEND_WEBHOOK_SECRET=

# Vercel Cron auth secret (32+ random chars)
CRON_SECRET=

# Portal token signing key — HMAC for /portal/[token] (32+ random chars)
PORTAL_SIGN_SECRET=

# Rate limiting (Upstash) — optional; when BOTH are set, per-IP limiting activates.
# NOTE: if you provision Redis via the Vercel Marketplace (Upstash) integration,
# Vercel injects KV_REST_API_URL / KV_REST_API_TOKEN instead of these names —
# rate-limit.ts falls back to those automatically, so either pair works.
# The limiter runs in Edge middleware, which inlines env at BUILD time: after
# adding the vars you must trigger a fresh build (git push), not a cache-reuse redeploy.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI workout parser (#16) — optional; enables "Parse with AI" on the programming import page.
ANTHROPIC_API_KEY=

# Twilio SMS (#42). All three required to enable SMS campaigns. TWILIO_SMS_FROM = UAE alphanumeric sender ID (e.g. CrossFitX).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# Twilio WhatsApp (#39). E.164 number of the approved WhatsApp sender (no whatsapp: prefix), e.g. +14155238886.
TWILIO_WHATSAPP_FROM=
