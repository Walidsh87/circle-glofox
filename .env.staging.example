# Staging environment template (L5 — prod/staging separation).
#
# Staging runs on a SECOND, isolated Supabase project + the Vercel "Preview"
# environment. Copy these into Vercel → Settings → Environment Variables →
# Preview (NOT Production). Everything not listed here is identical to
# .env.example; only the values below differ from production.

# ── MUST differ from prod (point at the staging Supabase project) ──
NEXT_PUBLIC_SUPABASE_URL=        # staging project URL (https://<ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # staging project anon key
SUPABASE_SERVICE_ROLE_KEY=       # staging project service-role key (server-only)

# Staging app origin — the Vercel preview/staging URL, NOT the prod domain.
NEXT_PUBLIC_APP_URL=             # e.g. https://staging.your-domain.com

# ── Separate secrets so a staging leak never affects prod ──
CRON_SECRET=                     # generate a DISTINCT 32+ char value for staging
PORTAL_SIGN_SECRET=              # generate a DISTINCT 32+ char value for staging

# ── Payments / comms: use TEST-mode / sandbox credentials in staging ──
# Stripe keys are per-gym (boxes.psp_credentials) — seed staging gyms with Stripe
# TEST keys + a staging webhook signing secret; never reuse live keys.
RESEND_API_KEY=                  # a staging Resend key (or the same key + a staging from-address)
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_WEBHOOK_SECRET=           # staging Resend webhook secret (optional)

# ── Optional integrations: leave blank in staging unless you are testing them ──
# Provide staging/sandbox values only for the feature under test; a blank value
# disables that feature (the app boots fine without it).
ANTHROPIC_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Sentry — point at a staging environment/DSN if you want staging errors separated.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
